{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Pagination": {
    "PageSize": 10
  },
  "RateLimiting": {
    "Enabled": true,
    "Global": {
      "PermitLimit": 30,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Login": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    }
  },
  "Cors": {
    "AllowedOrigins": [ "https://admin-ecommerce.marcuscfarias.com" ]
  },
  "KeyVault": {
    "VaultUri": ""
  },
  "ConnectionStrings": {
    "EcommerceDb": ""
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "ProductImageStorage": {
    "ServiceUri": "https://stecommerceimg.blob.core.windows.net/",
    "ContainerName": "product-images"
  },
  "Auth": {
    "Password": {
      "BcryptWorkFactor": 12
    },
    "Lockout": {
      "MaxFailedAttempts": 5,
      "LockoutMinutes": 15
    },
    "SeedUsers": {
      "Users": [
        {
          "Email": "owner@ecommerce.com",
          "Password": "Owner@123",
          "Name": "Demo Owner",
          "Role": "Owner"
        },
        {
          "Email": "manager@ecommerce.com",
          "Password": "Manager@123",
          "Name": "Demo Manager",
          "Role": "Manager"
        }
      ]
    }
  },
  "Jwt": {
    "Issuer": "ecommerce-platform",
    "Audience": "ecommerce-platform",
    "AccessTokenMinutes": 20,
    "RefreshTokenDays": 3
  }
}
