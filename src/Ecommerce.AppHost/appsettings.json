{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Pagination": {
    "PageSize": 10
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 30,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "ConnectionStrings": {
    "EcommerceDb": ""
  },
  "Auth": {
    "Password": {
      "BcryptWorkFactor": 12
    }
  },
  "Jwt": {
    "Issuer": "ecommerce-platform",
    "Audience": "ecommerce-platform",
    "AccessTokenMinutes": 20,
    "RefreshTokenDays": 3
  }
}
