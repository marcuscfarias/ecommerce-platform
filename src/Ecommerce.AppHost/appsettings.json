{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Pagination": {
    "PageSize": 10
  },
  "RateLimiting": {
    "Enabled": true,
    "Global": {
      "PermitLimit": 30,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Login": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    }
  },
  "Cors": {
    "AllowedOrigins": [ "https://admin-ecommerce.marcuscfarias.com" ]
  },
  "ConnectionStrings": {
    "EcommerceDb": ""
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "ProductImageStorage": {
    "ServiceUri": "",
    "ContainerName": "product-images"
  },
  "Auth": {
    "Password": {
      "BcryptWorkFactor": 12
    },
    "Lockout": {
      "MaxFailedAttempts": 5,
      "LockoutMinutes": 15
    }
  },
  "Jwt": {
    "Issuer": "ecommerce-platform",
    "Audience": "ecommerce-platform",
    "AccessTokenMinutes": 20,
    "RefreshTokenDays": 3
  }
}
