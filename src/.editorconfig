root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,xml,csproj,props,targets,slnx}]
indent_size = 2

[**/*Collection.cs]
# xUnit's [CollectionDefinition] target must be named *Collection — required by the
# framework for fixture sharing. Suffix is mandated by xUnit, not a naming smell.
dotnet_diagnostic.CA1711.severity = none

[**/*Tests/**.cs]
# Method_State_Should convention requires underscores (see feedback_test_naming).
dotnet_diagnostic.CA1707.severity = none

# Fixtures rely on xUnit's IAsyncLifetime to handle disposable field lifecycle;
# CA1001 doesn't recognize that contract and produces false positives.
dotnet_diagnostic.CA1001.severity = none

[**/Migrations/**.cs]
# Migrations are generated by the EF Core CLI; enforcing rules here would just
# create churn on every new migration.
generated_code = true
