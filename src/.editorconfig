root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,xml,csproj,props,targets,slnx}]
indent_size = 2

[*.cs]
# Promote uninitialized nullable from warning to error: latent bug, must break the build.
dotnet_diagnostic.CS8618.severity = error

# CA2007 (ConfigureAwait): rule for multi-context public libs. ASP.NET Core has no
# SynchronizationContext, so .ConfigureAwait(false) on every await is pure noise.
dotnet_diagnostic.CA2007.severity = none

# CA1848 (LoggerMessage delegates): hot-path optimization (>1k logs/sec). The ceremony
# of declaring compiled delegates doesn't pay off in regular controllers/handlers.
dotnet_diagnostic.CA1848.severity = none

[**/*Request.cs]
# Request DTOs route to Command/Query via ToCommand/ToQuery instance mappers
# (architectural pattern — controllers never `new Command(...)` inline). DTOs without
# fields don't access instance state, but keeping the call site as `request.ToCommand()`
# is the contract; making the mapper static would break it.
dotnet_diagnostic.CA1822.severity = none

[**/*Collection.cs]
# xUnit's [CollectionDefinition] target must be named *Collection — required by the
# framework for fixture sharing. Sufix is mandated by xUnit, not a naming smell.
dotnet_diagnostic.CA1711.severity = none

[**/*Tests/**.cs]
# Method_State_Should convention requires underscores (see feedback_test_naming).
dotnet_diagnostic.CA1707.severity = none

# Public test methods don't need XML docs — they're not part of any public API.
dotnet_diagnostic.CS1591.severity = none

# Fixtures rely on xUnit's IAsyncLifetime to handle disposable field lifecycle;
# CA1001 doesn't recognize that contract and produces false positives.
dotnet_diagnostic.CA1001.severity = none

[**/Migrations/**.cs]
# Migrations are generated by the EF Core CLI; enforcing rules here would just
# create churn on every new migration.
generated_code = true
