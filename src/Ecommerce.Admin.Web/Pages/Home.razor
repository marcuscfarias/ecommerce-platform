@page "/"
@layout MainLayout
@attribute [Authorize]
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation

<PageTitle>Dashboard · Ecommerce Backoffice</PageTitle>

<div class="shell">
    <header class="shell__bar">
        <span class="wordmark wordmark--dark">ecommerce</span>
        <div class="shell__bar-right">
            <span class="shell__user">@_email</span>
            <button type="button" class="shell__signout" @onclick="SignOutAsync">Sign out</button>
        </div>
    </header>

    <main class="shell__body">
        <h1>You're signed in.</h1>
        <p>This protected page confirms the route guard and authentication state are working.
            Catalog and user management land in the next slices.</p>
    </main>
</div>

@code {
    private string? _email;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        _email = state.User.FindFirst("email")?.Value
            ?? state.User.Identity?.Name
            ?? "Signed in";
    }

    private async Task SignOutAsync()
    {
        await ((TokenAuthenticationStateProvider)AuthState).SignOutAsync();
        Navigation.NavigateTo("login", replace: true);
    }
}
