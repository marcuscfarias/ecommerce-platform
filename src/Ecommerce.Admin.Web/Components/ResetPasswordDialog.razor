@inject UsersApiClient Users

<MudDialog>
    <DialogContent>
        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
        }

        <MudForm @ref="_form">
            <MudTextField @bind-Value="_password" Label="New password" Variant="Variant.Outlined"
                          Immediate="true" Validation="PasswordValidation" MaxLength="256"
                          InputType="InputType.Password" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="SubmitAsync" Disabled="_submitting">
            Reset password
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int UserId { get; set; }

    private MudForm _form = null!;
    private string _password = string.Empty;
    private bool _submitting;
    private string? _error;

    private async Task SubmitAsync()
    {
        await _form.Validate();
        if (!_form.IsValid)
        {
            return;
        }

        _submitting = true;
        _error = null;

        var outcome = await Users.ResetPasswordAsync(UserId, _password);

        if (!outcome.Succeeded)
        {
            _error = outcome.Error;
            _submitting = false;
            return;
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();

    private static readonly Func<string, IEnumerable<string>> PasswordValidation = ValidatePassword;

    private static IEnumerable<string> ValidatePassword(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            yield return "Enter a password.";
            yield break;
        }

        if (value.Length < 8 || value.Length > 256)
        {
            yield return "Password must be between 8 and 256 characters.";
        }

        if (!value.Any(char.IsLower) || !value.Any(char.IsUpper) || !value.Any(char.IsDigit))
        {
            yield return "Password must contain at least one lowercase letter, one uppercase letter, and one digit.";
        }
    }
}
